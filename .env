# NOVA AI Platform - Environment Variables
# ⚠️ SECURITY: DO NOT COMMIT THIS FILE TO GIT
# Add this to .gitignore

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
GENERATION_SERVICE_URL=http://localhost:8000

# ============================================
# DATABASE (PostgreSQL - Alibaba Cloud RDS)
# ============================================
DATABASE_URL=postgresql://novai_user:password@localhost:5432/novai_main

# ============================================
# REDIS (Alibaba Cloud Tair)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=novai-super-secret-jwt-key-min-32-chars-change-this
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================
# ALIBABA CLOUD DASHSCOPE ⚠️ SENSITIVE
# ============================================
# API Key provided by user
DASHSCOPE_API_KEY=sk-923407d300a844e08ed633a1be452b64
DASHSCOPE_REGION=singapore

# AI Models (Alibaba Cloud)
QWEN_IMAGE_MODEL=qwen-image-2.0-pro
WAN_T2V_MODEL=wan2.6-t2v
WAN_I2V_MODEL=wan2.1-i2v
QWEN_TEXT_MODEL=qwen-max

# ============================================
# ALIBABA CLOUD OSS (Object Storage Service)
# ============================================
OSS_BUCKET_NAME=novai-assets
OSS_REGION=ap-southeast-1
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
OSS_CDN_URL=https://novai-assets.oss-ap-southeast-1.aliyuncs.com

# ============================================
# PAYMENT
# ============================================
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SANDBOX=true

# ============================================
# MONITORING
# ============================================
SENTRY_DSN=
