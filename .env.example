# NOVA AI Platform - Environment Variables Template
# For Alibaba Cloud DashScope
# Copy this file to .env and fill in your values

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8080

# ============================================
# DATABASE (PostgreSQL - Alibaba Cloud RDS)
# ============================================
DATABASE_URL=postgresql://novai_user:PASSWORD@HOST:5432/novai_main

# ============================================
# REDIS (Alibaba Cloud Tair)
# ============================================
REDIS_URL=redis://HOST:6379

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth (optional - can use Alibaba Cloud IDaaS)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ============================================
# ALIBABA CLOUD DASHSCOPE
# ============================================
# Get API Key from: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_REGION=singapore

# AI Models (Alibaba Cloud)
# Text to Image: Qwen-Image series
QWEN_IMAGE_MODEL=qwen-image-2.0-pro

# Text to Video: Wanxiang Wan series
WAN_T2V_MODEL=wan2.6-t2v

# Image to Video: Wanxiang Wan series
WAN_I2V_MODEL=wan2.1-i2v

# Text Generation: Qwen series
QWEN_TEXT_MODEL=qwen-max

# ============================================
# ALIBABA CLOUD OSS (Object Storage Service)
# ============================================
OSS_BUCKET_NAME=novai-assets
OSS_REGION=ap-southeast-1
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_ENDPOINT=oss-ap-southeast-1.aliyuncs.com
OSS_CDN_URL=https://novai-assets.oss-ap-southeast-1.aliyuncs.com

# ============================================
# PAYMENT (Alibaba Cloud + Local)
# ============================================
# For Indonesia: Midtrans
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_SANDBOX=true

# For Alibaba Cloud: Alipay
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key

# ============================================
# EMAIL (SendGrid/Resend)
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@novaai.id

# ============================================
# MONITORING
# ============================================
SENTRY_DSN=your-sentry-dsn
ALIBABA_CLOUD_PROJECT_ID=your-project-id

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=60
RATE_LIMIT_ENTERPRISE=300

# ============================================
# CREDIT CONFIGURATION
# ============================================
CREDIT_FREE_MONTHLY=20
CREDIT_PRO_MONTHLY=300
CREDIT_T2V_BASE=5
CREDIT_T2I_BASE=2
CREDIT_I2V_BASE=7
CREDIT_TEXT_BASE=1
