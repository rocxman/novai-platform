# NOVA AI Platform - Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:8080

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/novai_dev

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ============================================
# GOOGLE AI STUDIO / VERTEX AI
# ============================================
GOOGLE_AI_API_KEY=your-google-ai-api-key
VERTEX_AI_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# AI Models
VEO_2_MODEL=veo-2.0-generate-001
IMAGEN_3_MODEL=imagen-3.0-generate-001
GEMINI_MODEL=gemini-1.5-pro

# ============================================
# GOOGLE CLOUD STORAGE
# ============================================
GCS_BUCKET_NAME=novai-assets-dev
GCS_PROJECT_ID=your-gcp-project-id
GCS_CDN_URL=https://cdn.novaai.id

# ============================================
# PAYMENT (MIDTRANS)
# ============================================
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_SANDBOX=true

# ============================================
# EMAIL (SENDGRID/RESEND)
# ============================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@novaai.id

# ============================================
# MONITORING
# ============================================
SENTRY_DSN=your-sentry-dsn
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_FREE=10
RATE_LIMIT_PRO=60
RATE_LIMIT_ENTERPRISE=300

# ============================================
# CREDIT CONFIGURATION
# ============================================
CREDIT_FREE_MONTHLY=20
CREDIT_PRO_MONTHLY=300
CREDIT_T2V_BASE=5
CREDIT_T2I_BASE=2
CREDIT_I2V_BASE=7
CREDIT_TEXT_BASE=1
