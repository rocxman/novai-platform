{
  "name": "api-gateway",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf dist node_modules",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx src/db/seed.ts",
    "docker:build": "docker build -t novai-api-gateway .",
    "docker:push": "docker push gcr.io/PROJECT_ID/novai-api-gateway:latest"
  },
  "dependencies": {
    "fastify": "^4.25.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^7.2.4",
    "@fastify/cookie": "^9.3.1",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/helmet": "^11.1.1",
    "@prisma/client": "^5.8.1",
    "ioredis": "^5.3.2",
    "bullmq": "^5.1.6",
    "zod": "^3.22.4",
    "jose": "^5.2.0",
    "google-auth-library": "^9.4.1",
    "@google-cloud/storage": "^7.7.0",
    "midtrans-client": "^1.3.1",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "vitest": "^1.2.1",
    "@vitest/coverage-v8": "^1.2.1",
    "prisma": "^5.8.1",
    "@types/node": "^20.11.0"
  }
}
